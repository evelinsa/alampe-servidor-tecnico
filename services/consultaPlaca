const fs = require('fs');
const path = require('path');

const bancoDir = path.join(__dirname, '..', 'banco');
const cachePath = path.join(bancoDir, 'cache_placas.json');
const historicoPath = path.join(bancoDir, 'historico_placas.json');

function garantirBanco() {
  if (!fs.existsSync(bancoDir)) fs.mkdirSync(bancoDir, { recursive: true });
  if (!fs.existsSync(cachePath)) fs.writeFileSync(cachePath, '[]', 'utf8');
  if (!fs.existsSync(historicoPath)) fs.writeFileSync(historicoPath, '[]', 'utf8');
}

function lerJSON(caminho, fallback = []) {
  try {
    garantirBanco();
    if (!fs.existsSync(caminho)) return fallback;
    const raw = fs.readFileSync(caminho, 'utf8');
    return raw ? JSON.parse(raw) : fallback;
  } catch {
    return fallback;
  }
}

function salvarJSON(caminho, dados) {
  garantirBanco();
  fs.writeFileSync(caminho, JSON.stringify(dados, null, 2), 'utf8');
}

function limparPlaca(placa = '') {
  return String(placa || '').toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 7);
}

function placaValida(placa = '') {
  const p = limparPlaca(placa);
  return /^[A-Z]{3}[0-9][A-Z0-9][0-9]{2}$/.test(p);
}

function normalizarTexto(valor = '') {
  return String(valor || '').trim().toUpperCase();
}

function respostaVazia(placa, origem, observacoes = []) {
  return {
    placa,
    origem,
    encontrado: false,
    cache: false,
    confianca: 'baixa',
    veiculo: {
      placa,
      marca: '',
      modelo: '',
      versao: '',
      anoFabricacao: '',
      anoModelo: '',
      motor: '',
      combustivel: '',
      cambio: '',
      cor: '',
      uf: '',
      municipio: '',
      carroceria: ''
    },
    preenchimentoOrcamento: {
      placa,
      veiculo: '',
      ano: '',
      motor: '',
      combustivel: '',
      cambio: '',
      cor: ''
    },
    buscaTecnicaContexto: {
      marca: '',
      modelo: '',
      ano: '',
      motor: ''
    },
    observacoes,
    atualizadoEm: new Date().toISOString()
  };
}

function montarRespostaPlaca(placa, dados, origem, extra = {}) {
  const d = dados || {};
  const marca = normalizarTexto(d.marca);
  const modelo = normalizarTexto(d.modelo);
  const versao = normalizarTexto(d.versao);
  const anoFabricacao = d.anoFabricacao || d.ano_fabricacao || d.ano || '';
  const anoModelo = d.anoModelo || d.ano_modelo || d.ano || anoFabricacao || '';
  const motor = normalizarTexto(d.motor);
  const combustivel = normalizarTexto(d.combustivel);
  const cambio = normalizarTexto(d.cambio);
  const cor = normalizarTexto(d.cor);
  const uf = normalizarTexto(d.uf);
  const municipio = normalizarTexto(d.municipio || d.cidade);
  const carroceria = normalizarTexto(d.carroceria);

  const encontrado = Boolean(marca || modelo || anoModelo || anoFabricacao);

  return {
    placa,
    origem,
    provider: extra.provider || origem,
    encontrado,
    cache: Boolean(extra.cache),
    confianca: extra.confianca || (encontrado ? 'media' : 'baixa'),
    veiculo: {
      placa,
      marca,
      modelo,
      versao,
      anoFabricacao,
      anoModelo,
      motor,
      combustivel,
      cambio,
      cor,
      uf,
      municipio,
      carroceria
    },
    preenchimentoOrcamento: {
      placa,
      veiculo: [marca, modelo].filter(Boolean).join(' '),
      ano: String(anoModelo || anoFabricacao || ''),
      motor,
      combustivel,
      cambio: cambio || 'MANUAL',
      cor
    },
    buscaTecnicaContexto: {
      marca,
      modelo,
      ano: anoModelo || anoFabricacao || '',
      motor
    },
    observacoes: [
      ...(extra.observacoes || []),
      'Confirmar os dados do veículo antes de concluir a venda.'
    ],
    atualizadoEm: new Date().toISOString()
  };
}

function registrarHistorico(placa, origem, sucesso = true) {
  const historico = lerJSON(historicoPath, []);
  historico.unshift({
    placa,
    origem,
    sucesso,
    data: new Date().toISOString()
  });
  salvarJSON(historicoPath, historico.slice(0, 500));
}

function buscarNoCache(placa) {
  const cache = lerJSON(cachePath, []);
  const item = cache.find(v => limparPlaca(v.placa) === placa);
  if (!item) return null;

  if (item.resposta) {
    return {
      ...item.resposta,
      origem: 'cache-local',
      provider: item.resposta.provider || 'cache-local',
      cache: true
    };
  }

  return montarRespostaPlaca(placa, item, 'cache-local', {
    provider: 'cache-local',
    cache: true,
    confianca: 'alta'
  });
}

function salvarNoCache(placa, resposta) {
  const cache = lerJSON(cachePath, []);
  const semDuplicar = cache.filter(v => limparPlaca(v.placa) !== placa);
  semDuplicar.unshift({
    placa,
    resposta,
    criadoEm: new Date().toISOString(),
    atualizadoEm: new Date().toISOString()
  });
  salvarJSON(cachePath, semDuplicar.slice(0, 1000));
}

function salvarPlacaManual(body = {}) {
  const placa = limparPlaca(body.placa);
  if (!placaValida(placa)) throw new Error('Placa inválida.');

  const dados = {
    marca: body.marca,
    modelo: body.modelo,
    versao: body.versao,
    anoFabricacao: body.anoFabricacao || body.ano_fabricacao || body.ano,
    anoModelo: body.anoModelo || body.ano_modelo || body.ano,
    motor: body.motor,
    combustivel: body.combustivel,
    cambio: body.cambio,
    cor: body.cor,
    uf: body.uf,
    municipio: body.municipio || body.cidade,
    carroceria: body.carroceria
  };

  const resposta = montarRespostaPlaca(placa, dados, 'cache-manual', {
    provider: 'cache-manual',
    cache: true,
    confianca: 'alta',
    observacoes: ['Registro manual salvo no cache do Alampe Core.']
  });

  salvarNoCache(placa, resposta);
  registrarHistorico(placa, 'cache-manual', true);

  return resposta;
}

