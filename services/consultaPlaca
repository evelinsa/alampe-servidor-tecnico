const fs = require('fs');
const path = require('path');

const bancoDir = path.join(__dirname, '..', 'banco');
const cachePath = path.join(bancoDir, 'cache_placas.json');
const historicoPath = path.join(bancoDir, 'historico_placas.json');

function garantirBanco() {
  if (!fs.existsSync(bancoDir)) fs.mkdirSync(bancoDir, { recursive: true });
  if (!fs.existsSync(cachePath)) fs.writeFileSync(cachePath, '[]', 'utf8');
  if (!fs.existsSync(historicoPath)) fs.writeFileSync(historicoPath, '[]', 'utf8');
}

function lerJSON(caminho, fallback = []) {
  try {
    garantirBanco();
    if (!fs.existsSync(caminho)) return fallback;
    const raw = fs.readFileSync(caminho, 'utf8');
    return raw ? JSON.parse(raw) : fallback;
  } catch {
    return fallback;
  }
}

function salvarJSON(caminho, dados) {
  garantirBanco();
  fs.writeFileSync(caminho, JSON.stringify(dados, null, 2), 'utf8');
}

function limparPlaca(placa = '') {
  return String(placa || '').toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 7);
}

function placaValida(placa = '') {
  const p = limparPlaca(placa);
  return /^[A-Z]{3}[0-9][A-Z0-9][0-9]{2}$/.test(p);
}

