async function providerHttpGenerico(placa) {
  const urlBase = process.env.PLACA_API_URL;
  if (!urlBase) return null;

  const token = process.env.PLACA_API_TOKEN || process.env.PLACA_API_KEY || '';
  const sep = urlBase.includes('?') ? '&' : '?';
  const url = `${urlBase}${sep}placa=${encodeURIComponent(placa)}`;

  const headers = {};
  if (token) {
    headers.Authorization = `Bearer ${token}`;
    headers['x-api-key'] = token;
  }

  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), 8000);

  try {
    const resp = await fetch(url, { headers, signal: controller.signal });
    clearTimeout(timeout);

    if (!resp.ok) {
      return respostaVazia(placa, 'provider-http', [
        `Provider HTTP retornou status ${resp.status}.`
      ]);
    }

    const json = await resp.json();

    const dados = json.veiculo || json.data || json.resultado || json;
    if (!dados) return null;

    return montarRespostaPlaca(placa, dados, 'provider-http', {
      provider: 'provider-http',
      confianca: 'alta',
      observacoes: ['Consulta realizada em provider HTTP configurado no Render.']
    });
  } catch (err) {
    clearTimeout(timeout);
    return respostaVazia(placa, 'provider-http', [
      `Provider HTTP falhou: ${err.message}`
    ]);
  }
}

async function consultarProviders(placa) {
  const tentativas = [];

  const http = await providerHttpGenerico(placa);
  if (http) {
    tentativas.push(http);
    if (http.encontrado) return { resposta: http, tentativas };
  }

  const local = providerLocalDemo(placa);
  if (local) {
    tentativas.push(local);
    if (local.encontrado) return { resposta: local, tentativas };
  }

  return {
    resposta: respostaVazia(placa, 'sem-provider-com-dados', [
      'Nenhum provider encontrou dados para esta placa.',
      'Configure PLACA_API_URL no Render ou salve a placa manualmente em /api/placa/cache.'
    ]),
    tentativas
  };
}

async function consultarPlaca(placaEntrada, opcoes = {}) {
  garantirBanco();
  const placa = limparPlaca(placaEntrada);

  if (!placaValida(placa)) {
    registrarHistorico(placa || 'INVALIDA', 'validacao', false);
    return {
      placa,
      encontrado: false,
      erro: 'Placa inválida. Use formato Mercosul ou antigo, com 7 caracteres.',
      exemplo: 'ABC1D23'
    };
  }

  if (!opcoes.forcar) {
    const cache = buscarNoCache(placa);
    if (cache) {
      registrarHistorico(placa, 'cache-local', true);
      return cache;
    }
  }

  const { resposta, tentativas } = await consultarProviders(placa);

  const final = {
    ...resposta,
    debug: {
      tentativas: tentativas.map(t => ({
        provider: t.provider || t.origem,
        encontrado: t.encontrado,
        confianca: t.confianca
      }))
    }
  };

  if (final.encontrado) salvarNoCache(placa, final);
  registrarHistorico(placa, final.provider || final.origem, final.encontrado);

  return final;
}

function historicoPlacas(limite = 50) {
  return lerJSON(historicoPath, []).slice(0, limite);
}

function diagnosticoProvidersPlaca() {
  return {
    cacheLocal: true,
    providerHttp: Boolean(process.env.PLACA_API_URL),
    providerHttpUrlConfigurada: Boolean(process.env.PLACA_API_URL),
    providerHttpTokenConfigurado: Boolean(process.env.PLACA_API_TOKEN || process.env.PLACA_API_KEY),
    providerLocalDemo: true,
    ordem: [
      'cache-local',
      'provider-http (se PLACA_API_URL estiver configurada)',
      'provider-local-demo',
      'sem-provider-com-dados'
    ],
    variaveisRender: [
      'PLACA_API_URL',
      'PLACA_API_TOKEN ou PLACA_API_KEY'
    ]
  };
}

module.exports = {
  consultarPlaca,
  historicoPlacas,
  limparPlaca,
  placaValida,
  diagnosticoProvidersPlaca,
  salvarPlacaManual
};
