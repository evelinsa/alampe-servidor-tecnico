}

function montarRespostaPlaca(placa, dados, origem) {
  const anoPrincipal = dados.anoModelo || dados.anoFabricacao || dados.ano || '';
  return {
    placa,
    origem,
    encontrado: true,
    confianca: origem === 'cache-local' ? 'alta' : 'media',
    veiculo: {
      marca: dados.marca || '',
      modelo: dados.modelo || '',
      versao: dados.versao || '',
      anoFabricacao: dados.anoFabricacao || dados.ano || '',
      anoModelo: dados.anoModelo || dados.ano || '',
      motor: dados.motor || '',
      combustivel: dados.combustivel || '',
      cambio: dados.cambio || '',
      cor: dados.cor || '',
      uf: dados.uf || '',
      municipio: dados.municipio || '',
      carroceria: dados.carroceria || ''
    },
    preenchimentoOrcamento: {
      placa,
      veiculo: [dados.marca, dados.modelo].filter(Boolean).join(' '),
      ano: String(anoPrincipal || ''),
      motor: dados.motor || '',
      combustivel: dados.combustivel || '',
      cambio: dados.cambio || 'MANUAL',
      cor: dados.cor || ''
    },
    buscaTecnicaContexto: {
      marca: dados.marca || '',
      modelo: dados.modelo || '',
      ano: anoPrincipal || '',
      motor: dados.motor || ''
    },
    observacoes: [
      dados.observacao || 'Confirmar os dados do veículo antes de concluir a venda.',
      'Consulta preparada para integração com API oficial/terceirizada de placa.'
    ],
    atualizadoEm: new Date().toISOString()
  };
}

function registrarHistorico(placa, origem, sucesso = true) {
  const historico = lerJSON(historicoPath, []);
  historico.unshift({
    placa,
    origem,
    sucesso,
    data: new Date().toISOString()
  });
  salvarJSON(historicoPath, historico.slice(0, 500));
}

async function consultarPlaca(placaEntrada) {
  garantirBanco();
  const placa = limparPlaca(placaEntrada);

  if (!placaValida(placa)) {
    registrarHistorico(placa || 'INVALIDA', 'validacao', false);
    return {
      placa,
      encontrado: false,
      erro: 'Placa inválida. Use formato Mercosul ou antigo, com 7 caracteres.',
      exemplo: 'ABC1D23'
    };
  }

  const cache = lerJSON(cachePath, []);
  const item = cache.find(v => limparPlaca(v.placa) === placa);

  if (item && item.resposta) {
    registrarHistorico(placa, 'cache-local', true);
    return {
      ...item.resposta,
      origem: 'cache-local',
      cache: true
    };
  }

  const dados = modeloPorPlaca(placa);
  const resposta = montarRespostaPlaca(placa, dados, 'base-local-simulada');

  cache.unshift({
    placa,
    resposta,
    criadoEm: new Date().toISOString(),
    atualizadoEm: new Date().toISOString()
  });

  salvarJSON(cachePath, cache.slice(0, 1000));
  registrarHistorico(placa, 'base-local-simulada', true);

  return {
    ...resposta,
    cache: false
  };
}

function historicoPlacas(limite = 50) {
  return lerJSON(historicoPath, []).slice(0, limite);
}

module.exports = {
  consultarPlaca,
  historicoPlacas,
  limparPlaca,
  placaValida
};
