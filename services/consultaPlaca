const fs = require('fs');
const path = require('path');

const cachePath = path.join(__dirname, '..', 'banco', 'cache_placas.json');
const historicoPath = path.join(__dirname, '..', 'banco', 'historico_placas.json');

function garantirArquivo(caminho, padrao = []) {
  const dir = path.dirname(caminho);
  if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true });
  if (!fs.existsSync(caminho)) fs.writeFileSync(caminho, JSON.stringify(padrao, null, 2));
}

function lerJSON(caminho, padrao = []) {
  try {
    garantirArquivo(caminho, padrao);
    const raw = fs.readFileSync(caminho, 'utf8');
    if (!raw.trim()) return padrao;
    return JSON.parse(raw);
  } catch (erro) {
    console.error('[consultaPlaca] erro ao ler JSON:', caminho, erro.message);
    return padrao;
  }
}

function salvarJSON(caminho, dados) {
  garantirArquivo(caminho, []);
  fs.writeFileSync(caminho, JSON.stringify(dados, null, 2));
}

function normalizarPlaca(placa = '') {
  return String(placa || '').toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 7);
}

function placaValida(placa = '') {
  const p = normalizarPlaca(placa);
  return /^[A-Z]{3}[0-9][A-Z0-9][0-9]{2}$/.test(p);
}

function registrarHistorico(item) {
  const historico = lerJSON(historicoPath, []);
  historico.unshift({
    data: new Date().toISOString(),
    ...item
  });
  salvarJSON(historicoPath, historico.slice(0, 500));
}

function listarHistoricoPlacas() {
  return lerJSON(historicoPath, []);
}

function buscarNoCache(placa) {
  const cache = lerJSON(cachePath, []);
  return cache.find(v => v.placa === placa) || null;
}

function salvarNoCache(placa, dados, origem = 'manual') {
  const cache = lerJSON(cachePath, []);
  const item = {
    placa,
    dados: normalizarDadosVeiculo(dados),
    origem,
    atualizadoEm: new Date().toISOString()
  };
  const idx = cache.findIndex(v => v.placa === placa);
  if (idx >= 0) cache[idx] = { ...cache[idx], ...item };
  else cache.unshift(item);
  salvarJSON(cachePath, cache.slice(0, 1000));
  return item;
}

function normalizarDadosVeiculo(dados = {}) {
  return {
    placa: normalizarPlaca(dados.placa || ''),
    marca: String(dados.marca || dados.fabricante || '').toUpperCase(),
    modelo: String(dados.modelo || '').toUpperCase(),
    versao: String(dados.versao || '').toUpperCase(),
    ano: String(dados.ano || dados.anoModelo || '').toUpperCase(),
    anoFabricacao: String(dados.anoFabricacao || '').toUpperCase(),
    anoModelo: String(dados.anoModelo || dados.ano || '').toUpperCase(),
    motor: String(dados.motor || '').toUpperCase(),
    combustivel: String(dados.combustivel || '').toUpperCase(),
    cambio: String(dados.cambio || '').toUpperCase(),
    cor: String(dados.cor || '').toUpperCase(),
    uf: String(dados.uf || '').toUpperCase(),
    municipio: String(dados.municipio || dados.cidade || '').toUpperCase()
  };
}

async function consultarProviderExterno(placa) {
  const urlBase = process.env.PLACA_API_URL;
  if (!urlBase) return null;

  const token = process.env.PLACA_API_TOKEN || '';
  const url = urlBase.includes('{placa}')
    ? urlBase.replace('{placa}', encodeURIComponent(placa))
    : `${urlBase}${urlBase.includes('?') ? '&' : '?'}placa=${encodeURIComponent(placa)}`;

  const headers = { 'Accept': 'application/json' };
  if (token) headers.Authorization = `Bearer ${token}`;

  const resp = await fetch(url, { headers });
  if (!resp.ok) throw new Error(`Provider placa retornou HTTP ${resp.status}`);
  const json = await resp.json();
  return normalizarDadosVeiculo({ placa, ...(json.veiculo || json.dados || json) });
}

async function consultarPlaca(placaEntrada) {
  const placa = normalizarPlaca(placaEntrada);

  if (!placa) {
    return { ok: false, erro: 'Informe a placa. Exemplo: /api/placa?placa=ABC1D23' };
  }

  if (!placaValida(placa)) {
    return { ok: false, placa, erro: 'Placa inválida. Use padrão antigo ou Mercosul com 7 caracteres.' };
  }

  const cache = buscarNoCache(placa);
  if (cache) {
    registrarHistorico({ placa, origem: 'cache', encontrou: true });
    return {
      ok: true,
      encontrou: true,
      origem: cache.origem || 'cache',
      cache: true,
      placa,
      veiculo: cache.dados,
      observacoes: ['Resultado carregado do cache local Alampe.']
    };
  }

  try {
    const externo = await consultarProviderExterno(placa);
    if (externo) {
      const salvo = salvarNoCache(placa, { ...externo, placa }, 'provider_externo');
      registrarHistorico({ placa, origem: 'provider_externo', encontrou: true });
      return {
        ok: true,
        encontrou: true,
        origem: 'provider_externo',
        cache: false,
        placa,
        veiculo: salvo.dados,
        observacoes: ['Resultado consultado em provider externo e salvo no cache.']
      };
    }
  } catch (erro) {
    registrarHistorico({ placa, origem: 'provider_externo', encontrou: false, erro: erro.message });
    return {
      ok: true,
      encontrou: false,
      origem: 'provider_externo_erro',
      cache: false,
      placa,
      veiculo: normalizarDadosVeiculo({ placa }),
      observacoes: [
        'Consulta externa de placa falhou.',
        'O servidor continua funcionando com cache local.',
        erro.message
      ]
    };
  }

  registrarHistorico({ placa, origem: 'sem_provider', encontrou: false });
  return {
    ok: true,
    encontrou: false,
    origem: 'sem_provider_configurado',
    cache: false,
    placa,
    veiculo: normalizarDadosVeiculo({ placa }),
    observacoes: [
      'Módulo de placa ativo.',
      'Nenhuma API de placa configurada ainda.',
      'Use POST /api/placa/cache para cadastrar uma placa manualmente ou configure PLACA_API_URL no Render.'
    ]
  };
}

function salvarPlacaManual(dados = {}) {
  const placa = normalizarPlaca(dados.placa);
  if (!placaValida(placa)) throw new Error('Placa inválida para salvar no cache.');
  const salvo = salvarNoCache(placa, { ...dados, placa }, 'manual');
  registrarHistorico({ placa, origem: 'manual', encontrou: true });
  return salvo;
}

module.exports = {
  consultarPlaca,
  listarHistoricoPlacas,
  salvarPlacaManual,
  normalizarPlaca,
  placaValida
};
